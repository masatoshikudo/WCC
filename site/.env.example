# Supabase（問い合わせ保存 Step3）— Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用。問い合わせ insert に使用（クライアントに含めない）
SUPABASE_SERVICE_ROLE_KEY=

# Resend（メール送信 Step4）— https://resend.com/api-keys
RESEND_API_KEY=
# 例: Wedding Content Creator <onboarding@resend.dev>（未検証ドメインは Resend の案内に従う）
RESEND_FROM=
# お問い合わせの社内通知先（任意。未設定ならお客様向け自動返信のみ）
CONTACT_NOTIFY_EMAIL=

# Stripe Payment Link（デポジット用）— ダッシュボードで作成した URL をそのまま貼り付け
# 成功時 URL は https://YOUR_DOMAIN/book?payment=success などに設定
NEXT_PUBLIC_STRIPE_DEPOSIT_PAYMENT_LINK=https://buy.stripe.com/...

