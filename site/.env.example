# Supabase（問い合わせ保存 Step3）— Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用。問い合わせ insert に使用（クライアントに含めない）
SUPABASE_SERVICE_ROLE_KEY=

# Resend（メール送信 Step4）— https://resend.com/api-keys
RESEND_API_KEY=
# 例: Wedding Content Creator <onboarding@resend.dev>（未検証ドメインは Resend の案内に従う）
RESEND_FROM=
# お問い合わせの社内通知先（任意。未設定ならお客様向け自動返信のみ）
CONTACT_NOTIFY_EMAIL=

# Stripe Payment Link（スタンダードパッケージ・一括決済用）— 金額に合わせて作成した URL を貼り付け
# 成功 URL 例: https://YOUR_DOMAIN/book?payment=success&session_id={CHECKOUT_SESSION_ID}
# キャンセル: https://YOUR_DOMAIN/book?payment=cancel
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_STANDARD=https://buy.stripe.com/...

# true または 1 で全ページを 503 メンテナンス表示（本番は Vercel Environment Variables で切替）
MAINTENANCE_MODE=

# 任意。next.config の distDir。設定時はビルド出力が .next ではなくここになる（`rm -rf .next` だけでは消えない）
# Dropbox 等で同期フォルダ内に置いている場合、.next の欠損で「e[o] is not a function」や pages-manifest 系の ENOENT が出やすい。
# そのときは同期対象外のパスを指定する例: NEXT_DIST_DIR=/tmp/wcc-next-dist または $HOME/Library/Caches/wcc-next-dist
# NEXT_DIST_DIR=.next-local
#
# `next dev` だけ: 既定では dist を OS の一時ディレクトリ（例: macOS の /var/folders/.../wcc-next-dev/<hash>）に出し、
# Dropbox と競合して CSS が 404・白画面になるのを避ける。プロジェクト直下の .next に戻す場合は 1 にする。
# NEXT_DEV_DIST_IN_PROJECT=1

# 管理画面 /admin/bookings（予約一覧）。パスワードとセッション署名用シークレット（十分に長いランダム文字列）
ADMIN_BOOKINGS_PASSWORD=
ADMIN_BOOKINGS_SECRET=

